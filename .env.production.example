# This path is inside the API container. Compose persists it to
# ./backend/data on the ECS disk.
DATABASE_URL=sqlite:////app/backend/data/kpl_bp.db

COMP_BASE_URL=https://prod.comp.smoba.qq.com
TGA_BASE_URL=https://tga-openapi.tga.qq.com
SYNC_REQUEST_DELAY=0.2

# Add exact origins only when a different domain calls the API directly.
CORS_ORIGINS=https://kpl.example.com
