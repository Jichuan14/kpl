# Use the RDS internal endpoint. URL-encode special characters in the password.
DATABASE_URL=mysql+pymysql://kpl_app:CHANGE_ME@rm-example.mysql.rds.aliyuncs.com:3306/kpl_lab?charset=utf8mb4

COMP_BASE_URL=https://prod.comp.smoba.qq.com
TGA_BASE_URL=https://tga-openapi.tga.qq.com
SYNC_REQUEST_DELAY=0.2

# Same-origin Nginx proxying does not require CORS. Add exact trusted origins
# here only if a separate frontend domain will call the API directly.
CORS_ORIGINS=https://kpl.example.com

