# SQLite by default (zero setup). For hosting, switch to Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/kpl_bp
DATABASE_URL=sqlite:///./data/kpl_bp.db

COMP_BASE_URL=https://prod.comp.smoba.qq.com
TGA_BASE_URL=https://tga-openapi.tga.qq.com

# Seconds between KPL API calls during sync (be polite)
SYNC_REQUEST_DELAY=0.2
