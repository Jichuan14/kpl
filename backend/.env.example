# MySQL is the primary application database. Replace the placeholder password
# with the local kpl_app credential created for your machine.
# DATABASE_URL=mysql+pymysql://kpl_app:your-url-encoded-password@127.0.0.1:3306/kpl_lab?charset=utf8mb4
# SQLite fallback (optional):
DATABASE_URL=sqlite:///./data/kpl_bp.db

COMP_BASE_URL=https://prod.comp.smoba.qq.com
TGA_BASE_URL=https://tga-openapi.tga.qq.com

# Seconds between KPL API calls during sync (be polite)
SYNC_REQUEST_DELAY=0.2
